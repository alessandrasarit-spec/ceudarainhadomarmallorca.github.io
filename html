<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Céu da Rainha do Mar · Luz · Amor · Unidade</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --azul-profundo: #0B3768;
    --azul-oceano: #2C6FA3;
    --azul-agua: #5FA8C9;
    --dourado-terra: #C2A05A;
    --dourado-luz: #E6C87A;
    --bege: #F8F0ED;
    --branco: #ffffff;
    --texto: #1a2a3a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Calibri', 'Trebuchet MS', sans-serif;
    background: var(--bege);
    color: var(--texto);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.4s ease;
  }
  nav.scrolled {
    background: rgba(11,55,104,0.96);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 20px rgba(0,0,0,0.25);
  }
  .nav-logo {
    width: 38px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  nav.scrolled .nav-logo { opacity: 1; }
  .nav-cta {
    display: inline-block;
    background: var(--dourado-terra);
    color: var(--azul-profundo);
    font-family: 'Lora', serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.55rem 1.4rem;
    text-decoration: none;
    border-radius: 2px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s ease;
  }
  nav.scrolled .nav-cta { opacity: 1; pointer-events: all; }
  .nav-cta:hover { background: var(--dourado-luz); }

  /* ── HERO ── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('data:image/jpeg;base64,');
    background-size: cover;
    background-position: center 40%;
    filter: brightness(0.5);
    animation: slowzoom 22s ease-in-out infinite alternate;
  }
  @keyframes slowzoom {
    from { transform: scale(1.04); }
    to { transform: scale(1.12); }
  }
  /* Gradient overlay — integrates the logo into the scene */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(11,55,104,0.55) 0%,
      rgba(11,55,104,0.15) 45%,
      rgba(11,55,104,0.7) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem;
    max-width: 820px;
    animation: fadein 1.6s ease;
  }
  @keyframes fadein {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Logo integrada — cores originais azul/dourado sobre fundo escuro */
  .hero-logo {
    width: 130px;
    margin-bottom: 1.8rem;
    filter:
      drop-shadow(0 0 16px rgba(230,200,122,0.4))
      drop-shadow(0 2px 30px rgba(0,0,0,0.5));
  }

  .urgencia-badge {
    display: inline-block;
    background: rgba(194,160,90,0.88);
    color: var(--azul-profundo);
    font-family: 'Lora', serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.45rem 1.4rem;
    border-radius: 2px;
    margin-bottom: 1.2rem;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    font-weight: 300;
    color: var(--branco);
    line-height: 1.1;
    text-shadow: 0 2px 24px rgba(0,0,0,0.45);
    margin-bottom: 0.4rem;
  }
  .hero h1 em {
    color: var(--dourado-luz);
    font-style: italic;
  }
  .hero-sub {
    font-family: 'Lora', serif;
    font-size: clamp(0.9rem, 1.8vw, 1.15rem);
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.06em;
    margin: 1rem 0 2rem;
    line-height: 1.6;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    background: var(--dourado-terra);
    color: var(--azul-profundo);
    font-family: 'Lora', serif;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.9rem 2.2rem;
    text-decoration: none;
    border-radius: 2px;
    transition: all 0.3s;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    letter-spacing: 0.04em;
  }
  .btn-primary:hover { background: var(--dourado-luz); transform: translateY(-2px); }
  .btn-ghost {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.6);
    color: var(--branco);
    font-family: 'Lora', serif;
    font-size: 0.95rem;
    padding: 0.9rem 2.2rem;
    text-decoration: none;
    border-radius: 2px;
    transition: all 0.3s;
    letter-spacing: 0.04em;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.12); }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    opacity: 0.6;
    animation: bounce 2.5s ease-in-out infinite;
  }
  @keyframes bounce {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(9px); }
  }
  .scroll-hint span { color: var(--branco); font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; }

  /* ── COMMON ── */
  section { padding: 5rem 1.5rem; }
  .container { max-width: 1080px; margin: 0 auto; }

  .section-label {
    font-family: 'Lora', serif;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--dourado-terra);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: center;
    justify-content: center;
  }
  .section-label::before, .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--dourado-terra);
    opacity: 0.4;
    max-width: 80px;
  }
  .label-light { color: var(--dourado-luz); }
  .label-light::before, .label-light::after { background: var(--dourado-luz); }

  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--azul-profundo);
    margin-bottom: 1.5rem;
  }
  h2 em { font-style: italic; color: var(--azul-oceano); }
  p { font-size: 0.97rem; line-height: 1.82; color: #3a4a5a; margin-bottom: 1rem; }

  /* ── CARTA ── */
  .carta { background: var(--azul-profundo); }
  .carta-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }
  @media(max-width:768px) { .carta-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

  .carta-foto {
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.45);
    position: relative;
  }
  .carta-foto::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(230,200,122,0.25);
    pointer-events: none;
  }
  .carta-foto img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .carta h2 { color: var(--branco); }
  .carta h2 em { color: var(--dourado-luz); }
  .carta p {
    color: rgba(255,255,255,0.8);
    font-family: 'Lora', serif;
    font-size: 0.93rem;
    font-style: italic;
    line-height: 1.92;
  }
  .firma {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(230,200,122,0.25);
  }
  .firma strong {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    color: var(--dourado-luz);
    font-style: normal;
    font-weight: 400;
    display: block;
    margin-bottom: 0.2rem;
  }
  .firma small { color: rgba(255,255,255,0.45); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; }

  /* ── HISTORIA ── */
  .historia { background: var(--bege); }
  .historia-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
    align-items: end;
  }
  @media(max-width:768px) { .historia-header { grid-template-columns: 1fr; } }

  .historia-foto {
    border-radius: 3px;
    overflow: hidden;
    height: 320px;
    box-shadow: 0 12px 40px rgba(11,55,104,0.14);
  }
  .historia-foto img { width: 100%; height: 100%; object-fit: cover; }

  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--dourado-terra), var(--azul-agua));
  }
  .timeline-item {
    position: relative;
    padding: 0 0 2.5rem 2rem;
    opacity: 0;
    transform: translateX(-18px);
    transition: all 0.6s ease;
  }
  .timeline-item.visible { opacity: 1; transform: translateX(0); }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -2rem; top: 0.4rem;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--dourado-terra);
    border: 2px solid var(--bege);
    box-shadow: 0 0 0 3px var(--dourado-terra);
  }
  .timeline-year {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--azul-oceano);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .timeline-title {
    font-family: 'Lora', serif;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--azul-profundo);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .timeline-text { font-size: 0.88rem; line-height: 1.72; color: #5a6a7a; margin: 0; }

  /* ── ESPACIO ── */
  .espacio { background: var(--azul-profundo); }
  .espacio-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media(max-width:768px) { .espacio-grid { grid-template-columns: 1fr; } }
  .espacio h2 { color: var(--branco); }
  .espacio h2 em { color: var(--dourado-luz); }
  .espacio p { color: rgba(255,255,255,0.78); }
  .espacio-foto { border-radius: 3px; overflow: hidden; box-shadow: 0 24px 60px rgba(0,0,0,0.5); }
  .espacio-foto img { width: 100%; height: 420px; object-fit: cover; display: block; }

  .razones { list-style: none; margin-top: 1.5rem; }
  .razones li {
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.09);
    color: rgba(255,255,255,0.8);
    font-size: 0.93rem;
    line-height: 1.65;
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
  }
  .razones li::before { content: '✦'; color: var(--dourado-luz); flex-shrink: 0; margin-top: 0.1rem; }
  .razones li strong { color: var(--branco); font-weight: 600; }

  /* ── METAS ── */
  .metas { background: var(--bege); text-align: center; }
  .metas-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 680px;
    margin: 2rem auto 2rem;
  }
  @media(max-width:580px) { .metas-grid { grid-template-columns: 1fr; } }
  .meta-card {
    background: var(--branco);
    border: 1px solid rgba(11,55,104,0.1);
    border-radius: 3px;
    padding: 2rem 1.5rem;
    box-shadow: 0 4px 20px rgba(11,55,104,0.07);
    transition: transform 0.3s;
  }
  .meta-card:hover { transform: translateY(-4px); }
  .meta-card.featured { border-color: var(--dourado-terra); }
  .meta-amount {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 300;
    color: var(--azul-profundo);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .meta-label {
    font-size: 0.78rem;
    color: var(--azul-oceano);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .meta-desc { font-size: 0.83rem; color: #7a8a9a; margin: 0; }

  .transparencia {
    background: var(--branco);
    border: 1px solid rgba(11,55,104,0.1);
    border-radius: 3px;
    padding: 1.5rem 2rem;
    max-width: 680px;
    margin: 1.5rem auto 2rem;
    text-align: left;
    font-size: 0.85rem;
    color: #5a6a7a;
    line-height: 1.7;
  }
  .transparencia strong { color: var(--azul-profundo); }

  .urgencia-strip {
    background: var(--dourado-terra);
    color: var(--azul-profundo);
    padding: 0.75rem 2rem;
    border-radius: 2px;
    font-family: 'Lora', serif;
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.06em;
    display: inline-block;
  }

  /* ── NIVELES ── */
  .niveles {
    position: relative;
    overflow: hidden;
  }
  .niveles-bg {
    position: absolute;
    inset: 0;
    background-image: url('data:image/jpeg;base64,');
    background-size: cover;
    background-position: center 30%;
    filter: brightness(0.22) saturate(0.8);
  }
  .niveles::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(11,55,104,0.7) 0%,
      rgba(11,55,104,0.4) 50%,
      rgba(11,55,104,0.75) 100%
    );
    z-index: 1;
  }
  .niveles .container {
    position: relative;
    z-index: 2;
  }
  .niveles > .container > h2 { color: var(--branco); text-align: center; margin-bottom: 0.5rem; }
  .niveles > .container > h2 em { color: var(--dourado-luz); }
  .niveles-desc {
    text-align: center;
    font-family: 'Lora', serif;
    font-style: italic;
    color: rgba(255,255,255,0.65);
    margin-bottom: 3rem;
    font-size: 0.95rem;
  }
  .niveles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    position: relative;
  }
  @media(max-width:768px) { .niveles-grid { grid-template-columns: 1fr; } }

  .nivel-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: 3px;
    padding: 2rem 1.5rem;
    transition: all 0.3s;
  }
  .nivel-card:hover { background: rgba(255,255,255,0.09); border-color: rgba(230,200,122,0.35); transform: translateY(-4px); }
  .nivel-card.featured { border-color: var(--dourado-terra); background: rgba(194,160,90,0.1); }
  .nivel-tag { font-family: 'Lora', serif; font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dourado-luz); margin-bottom: 0.4rem; }
  .nivel-nombre { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: var(--branco); margin-bottom: 0.2rem; }
  .nivel-precio { font-family: 'Lora', serif; font-size: 0.82rem; color: var(--dourado-luz); margin-bottom: 1.4rem; padding-bottom: 1.4rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .nivel-beneficios { list-style: none; }
  .nivel-beneficios li {
    color: rgba(255,255,255,0.78);
    font-size: 0.87rem;
    line-height: 1.6;
    padding: 0.4rem 0 0.4rem 1.2rem;
    position: relative;
  }
  .nivel-beneficios li::before { content: '·'; position: absolute; left: 0; color: var(--dourado-luz); font-size: 1.3rem; line-height: 1.1; }

  /* ── CONTRIBUIR ── */
  .contribuir { background: var(--bege); }
  .contribuir-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media(max-width:768px) { .contribuir-grid { grid-template-columns: 1fr; } }

  .metodo {
    background: var(--branco);
    border: 1px solid rgba(11,55,104,0.1);
    border-radius: 3px;
    padding: 1.4rem 1.6rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 10px rgba(11,55,104,0.05);
  }
  .metodo-title {
    font-family: 'Lora', serif;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--dourado-terra);
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .metodo-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    color: var(--azul-profundo);
    letter-spacing: 0.02em;
    line-height: 1.3;
  }
  .metodo-desc { font-size: 0.8rem; color: #8a9aaa; margin: 0.3rem 0 0; }

  /* QR integrado dentro do card do banco */
  .metodo-qr {
    display: flex;
    gap: 1.2rem;
    align-items: center;
  }
  .metodo-qr img {
    width: 90px;
    height: 90px;
    object-fit: contain;
    border-radius: 4px;
    flex-shrink: 0;
    border: 1px solid rgba(11,55,104,0.08);
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: white;
    font-family: 'Lora', serif;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 0.95rem 1.8rem;
    border-radius: 3px;
    text-decoration: none;
    margin-top: 1rem;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(37,211,102,0.28);
  }
  .btn-whatsapp:hover { background: #128C7E; transform: translateY(-2px); }

  .contribuir-foto {
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(11,55,104,0.14);
    position: sticky;
    top: 6rem;
  }
  .contribuir-foto img { width: 100%; height: 480px; object-fit: cover; display: block; }

  /* ── FOOTER ── */
  footer {
    background: var(--azul-profundo);
    color: rgba(255,255,255,0.55);
    text-align: center;
    padding: 3.5rem 1.5rem;
  }
  .footer-logo {
    width: 55px;
    margin-bottom: 1.2rem;
    filter: drop-shadow(0 0 8px rgba(230,200,122,0.3));
    opacity: 0.85;
  }
  .footer-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-style: italic;
    color: var(--dourado-luz);
    margin-bottom: 0.5rem;
  }
  footer small { font-size: 0.78rem; letter-spacing: 0.08em; }

  /* ── REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-left {
    opacity: 0;
    transform: translateX(-28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-left.visible { opacity: 1; transform: translateX(0); }
  .reveal-right {
    opacity: 0;
    transform: translateX(28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-right.visible { opacity: 1; transform: translateX(0); }
</style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <img src="data:image/png;base64," class="nav-logo" alt="CRM">
  <a href="#contribuir" class="nav-cta">Contribuir ahora</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <!-- Logo sin fondo, integrada con filtro blanco + resplandor dourado -->
    <img src="data:image/png;base64," class="hero-logo" alt="Céu da Rainha do Mar">
    <div class="urgencia-badge">⚡ Campaña urgente · Plazo junio 2026</div>
