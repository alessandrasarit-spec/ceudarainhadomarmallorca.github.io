<script>
  // Nav scroll behaviour
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 80);
  });

  // Intersection observer for all reveal classes
  const allReveal = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .timeline-item');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        const delay = entry.target.classList.contains('timeline-item')
          ? [...document.querySelectorAll('.timeline-item')].indexOf(entry.target) * 90
          : 0;
        setTimeout(() => entry.target.classList.add('visible'), delay);
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  allReveal.forEach(el => obs.observe(el));
</script>
